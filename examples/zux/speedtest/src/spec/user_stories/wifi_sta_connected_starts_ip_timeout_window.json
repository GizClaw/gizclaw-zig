{
  "kind": "UserStory",
  "spec": {
    "name": "wifi sta connected starts ip timeout window",
    "description": "A WiFi STA connected event records the connection timestamp and starts a no-timeout IP wait window.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "display": {
        "enabled": true,
        "brightness": 255
      },
      "smoke_status": {
        "round": 0,
        "ping_rtt_ms": 0,
        "up_bytes": 0,
        "down_bytes": 0,
        "up_total": 0,
        "down_total": 0,
        "up_mbps_milli": 0,
        "down_mbps_milli": 0,
        "duplex_up_mbps_milli": 0,
        "duplex_down_mbps_milli": 0,
        "cpu0_percent": 0,
        "cpu1_percent": 0,
        "mem_internal_free_kib": 0,
        "mem_psram_free_kib": 0
      },
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "inputs": [
          {
            "wifi_sta_connected": {
              "source_id": 2,
              "ssid_end": 7,
              "ssid_buf": "lab-net",
              "bssid": [
                16,
                32,
                48,
                64,
                80,
                96
              ],
              "channel": 6,
              "rssi": -41,
              "security": "wpa2"
            }
          }
        ],
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "connected": true,
              "has_ip": false,
              "connected_at": 1,
              "connect_timeout": false
            }
          }
        ]
      }
    ]
  }
}
