{
  "kind": "UserStory",
  "spec": {
    "name": "gizclaw connected event updates state",
    "description": "The GizClaw set-state custom event moves GizClaw state to connected.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "display": {
        "enabled": true,
        "brightness": 255
      },
      "smoke_status": {
        "round": 0,
        "ping_rtt_ms": 0,
        "up_bytes": 0,
        "down_bytes": 0,
        "up_total": 0,
        "down_total": 0,
        "up_mbps_milli": 0,
        "down_mbps_milli": 0,
        "duplex_up_mbps_milli": 0,
        "duplex_down_mbps_milli": 0,
        "cpu0_percent": 0,
        "cpu1_percent": 0,
        "mem_internal_free_kib": 0,
        "mem_psram_free_kib": 0
      },
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "connecting"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "custom": {
              "type": "gizclaw.set_state",
              "source_id": 3,
              "payload": {
                "state": "connected"
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "gizclaw_state",
            "state": {
              "state": "connected"
            }
          }
        ]
      }
    ]
  }
}
