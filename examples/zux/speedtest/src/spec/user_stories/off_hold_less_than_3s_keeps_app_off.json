        "round": 0,
        "ping_rtt_ms": 0,
        "up_bytes": 0,
        "down_bytes": 0,
        "up_total": 0,
        "down_total": 0,
        "up_mbps_milli": 0,
        "down_mbps_milli": 0,
        "duplex_up_mbps_milli": 0,
        "duplex_down_mbps_milli": 0,
        "cpu0_percent": 0,
        "cpu1_percent": 0,
        "mem_internal_free_kib": 0,
        "mem_psram_free_kib": 0
      },
      "app_state": {
        "state": "off"
      },
      "wifi_state": {
        "state": "off"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "button_gesture": {
