{
  "kind": "UserStory",
  "spec": {
    "name": "wifi sta connected without ip waits before timeout",
    "description": "When WiFi intent is on, a connected STA without IP stays in connected state and keeps the LED blue until the 3s IP timeout expires.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "strip": {},
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "inputs": [
          {
            "wifi_sta_connected": {
              "source_id": 2,
              "ssid_end": 7,
              "ssid_buf": "lab-net",
              "bssid": [
                16,
                32,
                48,
                64,
                80,
                96
              ],
              "channel": 6,
              "rssi": -41,
              "security": "wpa2"
            }
          }
        ],
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "status": "connected",
              "connected": true,
              "has_ip": false,
              "connected_at": 1,
              "connect_timeout": false
            }
          },
          {
            "label": "strip",
            "state": {
              "brightness": 255,
              "total_frames": 1,
              "current": {
                "pixels": [
                  {
                    "r": 0,
                    "g": 0,
                    "b": 255
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "wifi_sta_disconnected": {
              "source_id": 2,
              "reason": 8
            }
          }
        ],
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "status": "connected",
              "connected": true,
              "has_ip": false,
              "connected_at": 1,
              "connect_timeout": false
            }
          },
          {
            "label": "strip",
            "state": {
              "brightness": 255,
              "total_frames": 1,
              "current": {
                "pixels": [
                  {
                    "r": 0,
                    "g": 0,
                    "b": 255
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 2999999999,
          "n": 1
        },
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "status": "connected",
              "connected": true,
              "has_ip": false,
              "connected_at": 1,
              "connect_timeout": false
            }
          },
          {
            "label": "strip",
            "state": {
              "brightness": 255,
              "total_frames": 1,
              "current": {
                "pixels": [
                  {
                    "r": 0,
                    "g": 0,
                    "b": 255
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
