{
  "kind": "UserStory",
  "spec": {
    "name": "wifi sta disconnected event does not change app state",
    "description": "A WiFi STA disconnected event does not change app power state.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "strip": {},
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "wifi_sta_disconnected": {
              "source_id": 2,
              "reason": 7
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "app_state",
            "state": {
              "state": "on"
            }
          }
        ]
      }
    ]
  }
}
