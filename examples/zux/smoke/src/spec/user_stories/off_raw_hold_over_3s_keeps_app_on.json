{
  "kind": "UserStory",
  "spec": {
    "name": "off raw hold over 3s keeps app on",
    "description": "A single continuous raw press powers on after 3s and stays on while still held.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "strip": {},
      "app_state": {
        "state": "off"
      },
      "wifi_state": {
        "state": "off"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "raw_single_button": {
              "source_id": 1,
              "pressed": true
            }
          }
        ],
        "outputs": [
          {
            "label": "app_state",
            "state": {
              "state": "off"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 100000000,
          "n": 30
        },
        "outputs": [
          {
            "label": "app_state",
            "state": {
              "state": "on"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 100000000,
          "n": 20
        },
        "outputs": [
          {
            "label": "app_state",
            "state": {
              "state": "on"
            }
          }
        ]
      }
    ]
  }
}
