{
  "kind": "UserStory",
  "spec": {
    "name": "on hold less than 3s keeps wifi state",
    "description": "Holding Btn for less than 3s while on keeps the current WiFi intent.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "strip": {},
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 2999999999
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "wifi_state",
            "state": {
              "state": "on"
            }
          }
        ]
      }
    ]
  }
}
