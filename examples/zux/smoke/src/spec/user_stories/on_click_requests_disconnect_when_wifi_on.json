{
  "kind": "UserStory",
  "spec": {
    "name": "on click requests disconnect when wifi on",
    "description": "A short Btn click while on and WiFi intent on requests WiFi disconnect.",
    "initial_state": {
      "boot": {},
      "wifi": {
        "connected": true,
        "ssid_end": 11,
        "ssid_buf": "HAIVIVI-MFG"
      },
      "strip": {},
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "click": 1
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "wifi_state",
            "state": {
              "state": "off"
            }
          }
        ]
      }
    ]
  }
}
