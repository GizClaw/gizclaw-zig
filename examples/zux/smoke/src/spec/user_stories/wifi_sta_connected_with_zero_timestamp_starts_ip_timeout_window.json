{
  "kind": "UserStory",
  "spec": {
    "name": "wifi sta connected with zero timestamp starts ip timeout window",
    "description": "A connected WiFi STA with a zero connected_at timestamp starts its IP wait window on the next tick instead of timing out immediately.",
    "initial_state": {
      "boot": {},
      "wifi": {
        "connected": true,
        "has_ip": false,
        "connected_at": 0,
        "connect_timeout": false
      },
      "strip": {},
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "connected": true,
              "has_ip": false,
              "connected_at": 1,
              "connect_timeout": false
            }
          }
        ]
      }
    ]
  }
}
