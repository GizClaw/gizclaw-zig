{
  "kind": "UserStory",
  "spec": {
    "name": "wifi sta disconnected backs off before reconnect",
    "description": "When WiFi intent is on, a disconnected STA waits 5s before requesting reconnect.",
    "initial_state": {
      "boot": {},
      "wifi": {},
      "strip": {},
      "app_state": {
        "state": "on"
      },
      "wifi_state": {
        "state": "on"
      },
      "gizclaw_state": {
        "state": "disconnected"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "wifi_sta_disconnected": {
              "source_id": 2,
              "reason": 4
            }
          }
        ],
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "status": "disconnected",
              "connected": false,
              "has_ip": false,
              "reconnect_at": 5000000000
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 4999999999,
          "n": 1
        },
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "status": "disconnected",
              "connected": false,
              "has_ip": false,
              "reconnect_at": 5000000000
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "wifi",
            "state": {
              "status": "connecting",
              "connected": false,
              "has_ip": false,
              "reconnect_at": 0
            }
          }
        ]
      }
    ]
  }
}
