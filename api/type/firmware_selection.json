{
  "openapi": "3.0.3",
  "info": {
    "title": "Firmware Selection Type",
    "description": "Selected firmware release line and channel for a peer.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FirmwareSelection": {
        "type": "object",
        "required": [
          "id",
          "channel"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Firmware release-line id selected for the peer.",
            "example": "h106"
          },
          "channel": {
            "type": "string",
            "enum": [
              "stable",
              "beta",
              "develop",
              "pending"
            ],
            "description": "Firmware channel selected for the peer."
          }
        }
      }
    }
  }
}
