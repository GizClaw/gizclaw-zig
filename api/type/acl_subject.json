{
  "openapi": "3.0.3",
  "info": {
    "title": "ACL Subject Type",
    "description": "ACL subject identity schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ACLSubjectKind": {
        "type": "string",
        "description": "ACL subject identity kind.",
        "enum": [
          "pk",
          "view",
          "all_peers"
        ]
      },
      "ACLSubject": {
        "type": "object",
        "description": "ACL subject identity. Stored canonically as kind:id.",
        "required": [
          "kind",
          "id"
        ],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "$ref": "#/components/schemas/ACLSubjectKind"
          },
          "id": {
            "type": "string",
            "description": "Subject identifier for the selected kind.",
            "example": "z6Mk..."
          }
        }
      }
    }
  }
}
