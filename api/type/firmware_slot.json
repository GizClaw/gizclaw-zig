{
  "openapi": "3.0.3",
  "info": {
    "title": "Firmware Slot Type",
    "description": "Firmware slot schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FirmwareSlot": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "description": "Version carried by this slot.",
            "example": "1.0.3"
          },
          "description": {
            "type": "string",
            "example": "Devkit firmware 1.0.3"
          },
          "artifacts": {
            "type": "array",
            "description": "Device-defined artifact list for this slot.",
            "items": {
              "$ref": "./firmware_artifact.json#/components/schemas/FirmwareArtifact"
            }
          }
        }
      }
    }
  }
}
