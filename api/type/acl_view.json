{
  "openapi": "3.0.3",
  "info": {
    "title": "ACL View Type",
    "description": "ACLView schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ACLView": {
        "type": "object",
        "required": [
          "name",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "under-12"
          },
          "description": {
            "type": "string",
            "example": "Content view for children under 12."
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ACLViewSpec": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
