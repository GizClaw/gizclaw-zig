{
  "openapi": "3.0.3",
  "info": {
    "title": "ACL Resource Type",
    "description": "ACL resource identity schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ACLResourceKind": {
        "type": "string",
        "description": "ACL resource identity kind.",
        "enum": [
          "workspace",
          "workflow",
          "voice",
          "credential",
          "model",
          "view"
        ]
      },
      "ACLResource": {
        "type": "object",
        "description": "ACL resource identity. Stored canonically as kind:id.",
        "required": [
          "kind",
          "id"
        ],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "$ref": "#/components/schemas/ACLResourceKind"
          },
          "id": {
            "type": "string",
            "description": "Resource identifier for the selected kind.",
            "example": "demo"
          }
        }
      }
    }
  }
}
