{
  "openapi": "3.0.3",
  "info": {
    "title": "Model Type",
    "description": "Model schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Model": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "source",
          "provider",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "$ref": "./model_kind.json#/components/schemas/ModelKind"
          },
          "source": {
            "$ref": "./model_source.json#/components/schemas/ModelSource"
          },
          "provider": {
            "$ref": "./model_provider.json#/components/schemas/ModelProvider"
          },
          "name": {
            "type": "string",
            "example": "MiniMax M2.5"
          },
          "description": {
            "type": "string",
            "example": "OpenAI-compatible chat model"
          },
          "capabilities": {
            "$ref": "./model_capabilities.json#/components/schemas/ModelCapabilities"
          },
          "provider_data": {
            "$ref": "./model_provider_data.json#/components/schemas/ModelProviderData",
            "description": "Provider-specific model runtime configuration.",
            "example": {
              "upstream_model": "MiniMax-M2.5"
            }
          },
          "synced_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
