{
  "openapi": "3.0.3",
  "info": {
    "title": "Model Capabilities Type",
    "description": "Model capability schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ModelCapabilities": {
        "type": "object",
        "properties": {
          "json_output": {
            "type": "boolean"
          },
          "tool_calls": {
            "type": "boolean"
          },
          "text_only": {
            "type": "boolean"
          },
          "system_role": {
            "type": "boolean"
          },
          "temperature": {
            "type": "boolean"
          },
          "thinking": {
            "$ref": "#/components/schemas/ModelThinkingCapability"
          }
        }
      },
      "ModelThinkingCapability": {
        "type": "object",
        "required": [
          "supported"
        ],
        "properties": {
          "supported": {
            "type": "boolean"
          },
          "param": {
            "type": "string",
            "description": "Provider request parameter mapping, such as reasoning_effort, thinking.type, or enable_thinking."
          },
          "level_param": {
            "type": "string",
            "description": "Optional provider request parameter used for the selected thinking level or budget."
          },
          "levels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_level": {
            "type": "string"
          }
        }
      }
    }
  }
}
