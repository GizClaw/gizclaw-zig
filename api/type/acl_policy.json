{
  "openapi": "3.0.3",
  "info": {
    "title": "ACL Policy Type",
    "description": "ACL policy schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ACLPolicy": {
        "type": "object",
        "description": "ACL policy describing one subject-resource-role relation and optional validity window.",
        "required": [
          "subject",
          "resource",
          "role"
        ],
        "additionalProperties": false,
        "properties": {
          "subject": {
            "$ref": "./acl_subject.json#/components/schemas/ACLSubject"
          },
          "resource": {
            "$ref": "./acl_resource.json#/components/schemas/ACLResource"
          },
          "role": {
            "type": "string"
          },
          "not_before": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
