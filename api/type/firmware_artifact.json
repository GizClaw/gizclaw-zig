{
  "openapi": "3.0.3",
  "info": {
    "title": "Firmware Artifact Type",
    "description": "Firmware artifact schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FirmwareArtifact": {
        "type": "object",
        "required": [
          "name",
          "kind"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Device-defined artifact name.",
            "example": "main"
          },
          "kind": {
            "$ref": "./firmware_artifact_kind.json#/components/schemas/FirmwareArtifactKind"
          },
          "path": {
            "type": "string",
            "description": "Server-owned objectstore path for the uploaded artifact payload.",
            "example": "devkit/stable/app/20260613T000000.000000000Z-0123456789abcdef.bin"
          },
          "sha256": {
            "type": "string",
            "description": "Optional SHA-256 digest for integrity checks."
          },
          "size": {
            "type": "integer",
            "format": "int64",
            "description": "Optional artifact size in bytes."
          },
          "content_type": {
            "type": "string",
            "description": "Optional content type captured during upload.",
            "example": "application/octet-stream"
          },
          "uploaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "Server-owned upload timestamp."
          }
        }
      }
    }
  }
}
